{
  "name": "nhanaz/customtoast",
  "type": "library",
  "description": "A developer-friendly PocketMine-MP virion for sending custom Bedrock toast notifications",
  "license": "LGPL-3.0-or-later",
  "require": {
    "php": "^8.1",
    "ext-mbstring": "*",
    "ext-zip": "*",
    "pocketmine/pocketmine-mp": "^5.0.0"
  },
  "autoload": {
    "psr-4": {
      "NhanAZ\\CustomToast\\": "src/NhanAZ/CustomToast/"
    }
  },
  "extra": {
    "virion": {
      "spec": "3.0",
      "namespace-root": "NhanAZ\\CustomToast"
    }
  }
}
